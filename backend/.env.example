# Backend environment variables for Decentralized Raffle Ticketing System

# Deployed Raffle smart contract address on Sepolia
CONTRACT_ADDRESS=

# Admin wallet private key used by backend to trigger pickWinner()
# Never commit real keys to version control
PRIVATE_KEY=

# Ethereum Sepolia RPC endpoint (Alchemy/Infura/etc.)
RPC_URL=

# Backend server port
PORT=5000
