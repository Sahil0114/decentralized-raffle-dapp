# Backend environment variables for Decentralized Raffle Ticketing System

# Optional override. If empty, backend reads from:
# backend/src/abi/deployment.json (auto-generated by local deploy)
CONTRACT_ADDRESS=

# Optional. If empty on localhost, backend uses node account[0] signer.
PRIVATE_KEY=

# Optional override (defaults to local hardhat node)
RPC_URL=http://127.0.0.1:8545

# Backend server port
PORT=5000
