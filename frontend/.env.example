# Frontend environment variables for Decentralized Raffle Ticketing System

# Deployed Raffle smart contract address (Sepolia)
VITE_CONTRACT_ADDRESS=

# Sepolia RPC URL (optional for read-only fallback when wallet provider is unavailable)
VITE_RPC_URL=

# Wallet address allowed to see AdminPanel in UI
VITE_ADMIN_ADDRESS=

# Backend base URL for API requests
# Example: http://localhost:5000
VITE_BACKEND_BASE_URL=
