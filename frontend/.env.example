# Frontend environment variables for Decentralized Raffle Ticketing System

# Optional override. If empty, frontend reads from:
# frontend/src/constants/deployment.json (auto-generated by local deploy)
VITE_CONTRACT_ADDRESS=

# Optional override (defaults to local hardhat node)
VITE_RPC_URL=http://127.0.0.1:8545

# Optional override. If empty, frontend uses deployer address from deployment metadata.
VITE_ADMIN_ADDRESS=

# Backend base URL for API requests
VITE_BACKEND_BASE_URL=http://localhost:5000

# Optional chain/explorer override for tx/address links
VITE_CHAIN_ID=31337
VITE_EXPLORER_BASE_URL=
